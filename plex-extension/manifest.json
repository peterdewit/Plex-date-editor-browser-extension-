{
  "manifest_version": 3,
  "name": "Plex Date Bump",
  "version": "1.1.0",
  "description": "Move the current Plex item back in Recently Added by changing addedAt.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Plex Date Bump",
    "default_popup": "popup.html"
  }
}
